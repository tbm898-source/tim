<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tim.classroom-bridge</string>
  <key>ProgramArguments</key>
  <array>
    <string>PLACEHOLDER_RUN_SCRIPT</string>
  </array>
  <key>WorkingDirectory</key>
  <string>PLACEHOLDER_TIM_ROOT</string>
  <key>StandardOutPath</key>
  <string>PLACEHOLDER_LOG_DIR/classroom-bridge.log</string>
  <key>StandardErrorPath</key>
  <string>PLACEHOLDER_LOG_DIR/classroom-bridge-error.log</string>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>30</integer>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
